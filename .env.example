# このファイルを .env にコピーして値を設定してください。

# --- Discord通知 ---
# trueにしないと(Webhook URLを設定していても)一切通知しません(既定OFF)。
DISCORD_ENABLED=true
# DiscordのWebhook URL(サーバー設定 → 連携サービス → Webhook で発行する)。
DISCORD_WEBHOOK_URL=
# スコアが100点満点のトークンだけを追加で通知する専用チャンネルのWebhook
# URL(任意、未設定なら送らない)。
DISCORD_PERFECT_SCORE_WEBHOOK_URL=
# 既に通知済みのトークンが、後のチェックポイントで初めてユニーク買い手
# ★1つ以上を確認できた瞬間に送る「追い通知」専用チャンネルのWebhook URL
# (任意、未設定なら送らない。1トークンにつき最大1回だけ送る)。
DISCORD_FOLLOWUP_WEBHOOK_URL=
# 通知に載せるPhantom起動リンクに付ける紹介コード(任意、個人のPhantom
# アプリの設定等で確認できる値)。未設定でもリンク自体は生成される。
PHANTOM_REFERRAL_ID=

# 通知本文で使う絵文字(任意)。Discordサーバーで作ったカスタム絵文字の
# `<:名前:ID>`形式に差し替え可能(既定は標準の絵文字)。
DISCORD_HOLDER_CONCENTRATION_WARN_EMOJI=⚠️
DISCORD_HOLDER_CONCENTRATION_HEALTHY_EMOJI=✅
DISCORD_DUPLICATE_NAME_EMOJI=🚨
DISCORD_TWITTER_EMOJI=🐦
DISCORD_TELEGRAM_EMOJI=✈️

# ダッシュボードの公開URL(例: http://76.13.180.239:8790)。設定すると、
# Discord通知に「詳細」ボタン(このURLの/token/{mint}へのリンク)が付く
# (未設定なら「詳細」ボタンは付かず、「Phantomで開く」ボタンだけになる)。
DASHBOARD_PUBLIC_URL=

# --- PumpPortal WebSocket接続 ---
# 通常は変更不要(無料・APIキー不要の公開エンドポイント)。
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
# 接続が切れた場合に再接続を試みるまでの待機秒数。
RECONNECT_DELAY_SECONDS=5

# --- DexScreener REST API接続 ---
# 通常は変更不要(無料・APIキー不要の公開エンドポイント)。
DEXSCREENER_API_BASE_URL=https://api.dexscreener.com

# --- RugCheck REST API接続 ---
# 通常は変更不要(無料・APIキー不要の公開エンドポイント)。
RUGCHECK_API_BASE_URL=https://api.rugcheck.xyz

# --- Solana RPC接続(ユニーク買い手数の集計) ---
# 通常は変更不要(無料・APIキー不要の公開エンドポイント、ただしレート制限が
# 厳しいことがある)。安定させたい場合はhelius.dev等の無料APIキー付きURLを
# 設定することを推奨(README.mdの「Solana RPC連携」参照)。
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# 1回の集計で読む取引数の上限(多いほど正確だがRPC呼び出しが増える)。
SOLANA_MAX_SIGNATURES_PER_CHECKPOINT=20
SOLANA_RPC_CONCURRENCY=5
SOLANA_UNIQUE_BUYERS_WINDOW_SECONDS=300

# --- 卒業後の観察・スコアリング(チェックポイントは0/60/300/900秒固定) ---
# 同時に観察できるトークン数の上限。
MAX_TRACKED_TOKENS=500
# チェックポイントを迎えたトークンを同時に何件まで並行処理するか(上げ
# すぎると各APIのレート制限に引っかかりやすくなる)。
CHECKPOINT_CONCURRENCY=8
# 直近5分の出来高(USD建て)がこれ以上なら加点する。
MIN_VOLUME_USD_FOR_SCORE=300.0
# 流動性(USD建て)がこれ未満だと加点しない。
MIN_LIQUIDITY_USD_FOR_SCORE=2000.0
# RugCheckの上位10保有者合計保有率(%)がこれ以上なら集中しすぎ(⚠️)。
HOLDER_CONCENTRATION_WARN_THRESHOLD_PCT=50.0
# 上記がこれ未満なら健全に分散している(✅)。
HOLDER_CONCENTRATION_HEALTHY_THRESHOLD_PCT=20.0

# --- 通知レベルのスコア閾値(0-100点) ---
# score >= HIGH_SCORE_THRESHOLD: 🚨 HIGH PRIORITY(Discord通知)
HIGH_SCORE_THRESHOLD=75
# score >= WATCH_SCORE_THRESHOLD: ⚠ WATCH(Discord通知)
WATCH_SCORE_THRESHOLD=70
# score >= LOW_SCORE_THRESHOLD: ログ保存のみ(Discordへは送らない)
LOW_SCORE_THRESHOLD=35

# --- 通知後の結果トラッキング ---
# JSONLの出力先(未設定なら logs/outcomes.jsonl)。
OUTCOMES_FILE_PATH=

# --- 発行者ブラックリスト ---
# ブラックリストのJSON出力先(未設定なら logs/creator_blocklist.json)。
CREATOR_BLOCKLIST_FILE_PATH=
# 通知後、時価総額がこの割合(マイナス値)以上下落したら「暴落」とみなし、
# その発行者をブロックリストへ追加する。
CREATOR_BLOCKLIST_CRASH_THRESHOLD_PCT=-90.0

# --- 名前/ティッカー重複履歴(なりすまし対策) ---
# 既に見た名前/ティッカーを別mintが後から名乗った場合に検出するための
# 記録先(未設定なら logs/token_name_history.json)。
TOKEN_NAME_HISTORY_FILE_PATH=

# --- 自動売買(trade_executor.py。⚠️⚠️⚠️既定OFF。実際にウォレットの資金
# を動かす実験的機能。有効化する前に必ずREADME.mdの「自動売買
# (実験的機能)」を読むこと。少額専用の新規ウォレットの使用を強く推奨) ---
# 以下の2つを両方trueにしない限り一切動かない(事故防止の二重ゲート)。
AUTO_TRADE_ENABLED=false
AUTO_TRADE_CONFIRMED_RISK=false
# ウォレットの秘密鍵(base58形式、Phantom等の「秘密鍵をエクスポート」で
# 取得)。この値を持つ者はウォレットの全資金を動かせるため絶対に他人に
# 見せない・コミットしない。少額専用の新規ウォレット推奨。
SOLANA_WALLET_PRIVATE_KEY=
# このスコア以上(既定100=満点)のトークンだけ自動購入の対象にする。
AUTO_TRADE_MIN_SCORE=100
# DEX卒業からの経過秒数がこれ以下でのみ自動購入する(初期のコインを狙う)。
AUTO_TRADE_MAX_ELAPSED_SECONDS_FOR_ENTRY=60
# 1回の購入に使うSOL量。
AUTO_TRADE_BUY_AMOUNT_SOL=0.02
# 同時に保有できる建玉数の上限。
AUTO_TRADE_MAX_OPEN_POSITIONS=3
# スワップのスリッページ許容(ベーシスポイント、100=1%)。
AUTO_TRADE_SLIPPAGE_BPS=500
# 含み益がこの%以上で自動利確。
AUTO_TRADE_TAKE_PROFIT_PCT=50.0
# 含み損がこの%(マイナス値)以下で自動損切り。
AUTO_TRADE_STOP_LOSS_PCT=-30.0
# 利確/損切りに達しないまま保有し続けた場合の強制手仕舞いまでの秒数。
AUTO_TRADE_MAX_HOLD_SECONDS=3600
# 建玉監視の間隔(秒)。
AUTO_TRADE_POSITION_POLL_SECONDS=15
# 建玉状態・取引ログの出力先(未設定ならlogs/positions.json・logs/trades.jsonl)。
POSITIONS_FILE_PATH=
TRADES_FILE_PATH=
# 自動売買の実行結果(買い/売り)を通知する専用チャンネルのWebhook URL
# (任意、未設定なら通知しない。通常のDISCORD_WEBHOOK_URLとは別チャンネル推奨)。
DISCORD_TRADE_WEBHOOK_URL=

# --- パーペチュアル(perp_sniper.py、実験的機能。本体[main.py]とは完全に
# 独立した別プロセス。既定OFF) ---
PERP_ENABLED=false
# 監視する銘柄(カンマ区切り、Binance Futuresのシンボル表記)。
PERP_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
PERP_API_BASE_URL=https://fapi.binance.com
# シグナルを再計算する間隔(秒)。
PERP_POLL_INTERVAL_SECONDS=900
PERP_KLINE_INTERVAL=1h
PERP_KLINE_LIMIT=100
# シグナル強度(-100〜100)がこの絶対値以上でLONG/SHORTと判定する。
PERP_SIGNAL_THRESHOLD=40
# シグナル通知専用のWebhook URL(任意、未設定なら送らない)。
DISCORD_PERP_WEBHOOK_URL=
# ペーパートレード(モック、実資金は一切動かさない)。既定ON。
PERP_PAPER_TRADING_ENABLED=true
PERP_PAPER_LEVERAGE=3.0
PERP_PAPER_TAKE_PROFIT_PCT=10.0
PERP_PAPER_STOP_LOSS_PCT=-10.0
PERP_PAPER_MAX_HOLD_SECONDS=86400
PERP_POSITIONS_FILE_PATH=

# --- グリッドトレード・ペーパートレード(perp_grid_backtest.pyで検証した
# 戦略、実資金は動かさない。トレンド戦略[PERP_PAPER_*]とは別、既定OFF) ---
PERP_GRID_ENABLED=false
# 以下はPERP_SYMBOLSに無い銘柄・下記の銘柄別上書きが無い銘柄に使われる
# グローバル既定値。
PERP_GRID_RANGE_PCT=10.0
PERP_GRID_COUNT=100
PERP_GRID_TAKE_PROFIT_PCT=0.2
PERP_GRID_STOP_LOSS_PCT=-0.1
# 銘柄ごとの上書き(任意、PERP_GRID_COUNT_<SYMBOL>等)。BTCUSDT/ETHUSDT/
# SOLUSDTは、この行が無くてもconfig.PERP_GRID_SYMBOL_DEFAULTS(2026-07、
# perp_grid_backtest_sweep.pyでの実測に基づく)がコード側の既定値として
# 自動的に使われる。ここで明示的に指定すると、その値が最優先で使われる
# (実測をさらに自分で調整したい場合のみ設定すればよい)。
# 例: PERP_GRID_COUNT_BTCUSDT=100
#     PERP_GRID_TAKE_PROFIT_PCT_BTCUSDT=0.4
#     PERP_GRID_STOP_LOSS_PCT_BTCUSDT=-0.5
PERP_GRID_LEVERAGE=3.0
# Hyperliquid実際のMaker手数料(2026-07時点0.015%)を既定値にしている。
PERP_GRID_FEE_PCT_PER_SIDE=0.015
# trueで売りグリッド(両建て)も同時にペーパートレードする(既定false)。
# 必要証拠金・含み損リスクが実質倍になる点に注意(README参照)。
PERP_GRID_SHORT_ENABLED=false
PERP_GRID_POLL_INTERVAL_SECONDS=30
# 取引が非常に多いため、集計をこの間隔(秒、既定24時間)ごとに通知する。
PERP_GRID_SUMMARY_INTERVAL_SECONDS=86400
PERP_GRID_POSITIONS_FILE_PATH=

# --- グリッドトレードの実発注(Hyperliquid。⚠️⚠️⚠️既定OFF。実際にウォレット
# の資金を動かす実験的機能。有効化する前に必ずREADME.mdの「パーペチュアル
# 実発注(Hyperliquid、実験的機能)」を読むこと。少額専用の新規ウォレット・
# まずテストネットでの使用を強く推奨) ---
# 以下の2つを両方trueにしない限り一切動かない(事故防止の二重ゲート)。
PERP_GRID_LIVE_ENABLED=false
PERP_GRID_LIVE_CONFIRMED_RISK=false
# Hyperliquid用ウォレットの秘密鍵(Ethereum形式、0xで始まる16進数)。
# この値を持つ者はウォレットの全資金を動かせるため絶対に他人に見せない・
# コミットしない。少額専用の新規ウォレット推奨。
HYPERLIQUID_PRIVATE_KEY=
# true推奨。まずテストネットで動作確認してから本番(false)へ切り替えること。
HYPERLIQUID_USE_TESTNET=true
# 1グリッドあたりの発注額(USD建て)。
PERP_GRID_LIVE_ORDER_USD=10.0
# 同時に保有できるグリッド建玉数の上限。
PERP_GRID_LIVE_MAX_OPEN_POSITIONS=5
# 成行注文のスリッページ許容(0.01=1%)。
PERP_GRID_LIVE_SLIPPAGE=0.01
# market_open/market_closeはTaker扱いになるため、Maker手数料より高い
# Taker手数料(2026-07時点0.045%)を既定値にしている(損益表示の目安計算用)。
PERP_GRID_LIVE_FEE_PCT_PER_SIDE=0.045
PERP_GRID_LIVE_POSITIONS_FILE_PATH=

# --- Supabase(通知履歴・結果・発行者ブラックリストの永続化、ダッシュボードの
# データソース。任意、未設定ならローカルのJSON/JSONLだけで動く) ---
# プロジェクトのURL(Supabaseダッシュボード Settings → API → Project URL)。
SUPABASE_URL=
# service_role キー(Settings → API → service_role secret)。秘密鍵。
SUPABASE_SERVICE_ROLE_KEY=

# --- ダッシュボード(dashboard_server.py、任意。Supabase未設定でも起動は
# できるが、データは空のまま表示される) ---
DASHBOARD_SERVER_HOST=0.0.0.0
DASHBOARD_SERVER_PORT=8790
# 簡易保護用のトークン(任意)。設定するとダッシュボードのページ上部で
# 同じ値を入力しない限り/api/*が401を返す。
DASHBOARD_API_TOKEN=
# 「直近の通知」一覧に表示する最大件数。
DASHBOARD_RECENT_NOTIFICATIONS_LIMIT=50

# --- チャット返信Bot(chat_reply_bot.py、任意。特定の1人が特定の言葉を
# 発言したら固定の返信を送るだけの遊び機能。本体のスキャナーとは無関係
# なので未設定でも本体には一切影響しない。手順はREADME.md参照) ---
CHAT_REPLY_ENABLED=false
# Discord Developer PortalでBotを作成して発行したトークン(秘密鍵)。
DISCORD_BOT_TOKEN=
# 反応する相手のDiscordユーザーID(数値)。
CHAT_REPLY_TARGET_USER_ID=
# 「この言葉を含む発言→この返信」のペアを番号付きで好きなだけ登録できる
# (最大10個、_1から順に。空欄のままなら未使用)。
CHAT_REPLY_TRIGGER_WORD_1=おはよう
CHAT_REPLY_MESSAGE_1=おはよー!♥️
CHAT_REPLY_TRIGGER_WORD_2=おやすみ
CHAT_REPLY_MESSAGE_2=おやすみ~
CHAT_REPLY_TRIGGER_WORD_3=可愛い
CHAT_REPLY_MESSAGE_3=ありがとー!!

# --- ログ ---
LOG_LEVEL=INFO
