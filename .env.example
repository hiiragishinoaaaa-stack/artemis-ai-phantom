# このファイルを .env にコピーして値を設定してください。

# --- Discord通知 ---
# trueにしないと(Webhook URLを設定していても)一切通知しません(既定OFF)。
DISCORD_ENABLED=true
# DiscordのWebhook URL(サーバー設定 → 連携サービス → Webhook で発行する)。
DISCORD_WEBHOOK_URL=

# --- PumpPortal WebSocket接続 ---
# 通常は変更不要(無料・APIキー不要の公開エンドポイント)。
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
# 接続が切れた場合に再接続を試みるまでの待機秒数。
RECONNECT_DELAY_SECONDS=5

# --- 初動観察・フィルター条件 ---
# 新規トークン作成を検知してから、この秒数だけ売買を観察してから判定する。
OBSERVATION_WINDOW_SECONDS=45
# 観察期間中の買い件数がこれ未満なら通知しない。
MIN_BUY_COUNT=5
# 観察期間中のユニークな買い手がこれ未満なら通知しない。
MIN_UNIQUE_BUYERS=3
# 観察期間中の売り件数が「買い件数×この倍率」を超えたら通知しない。
MAX_SELL_TO_BUY_RATIO=1.0
# 観察終了時点の時価総額(SOL建て)がこれ未満なら通知しない。0以下で無効。
MIN_MARKET_CAP_SOL=0
# 同時に観察できるトークン数の上限。
MAX_TRACKED_TOKENS=500

# --- ログ ---
LOG_LEVEL=INFO
