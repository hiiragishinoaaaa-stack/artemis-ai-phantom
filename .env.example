# このファイルを .env にコピーして値を設定してください。

# --- Discord通知 ---
# trueにしないと(Webhook URLを設定していても)一切通知しません(既定OFF)。
DISCORD_ENABLED=true
# DiscordのWebhook URL(サーバー設定 → 連携サービス → Webhook で発行する)。
DISCORD_WEBHOOK_URL=

# --- PumpPortal WebSocket接続 ---
# 通常は変更不要(無料・APIキー不要の公開エンドポイント)。
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
# 接続が切れた場合に再接続を試みるまでの待機秒数。
RECONNECT_DELAY_SECONDS=5

# --- 初動観察・スコアリング(チェックポイントは20/40/60/90/120秒固定) ---
# 同時に観察できるトークン数の上限。
MAX_TRACKED_TOKENS=500
# Volume(SOL建て、買い+売りの累計)がこれ以上なら加点する。
MIN_VOLUME_SOL_FOR_SCORE=5.0
# 時価総額(SOL建て)がこれ未満だと加点しない。
MIN_MARKET_CAP_SOL_FOR_SCORE=15.0

# --- 通知レベルのスコア閾値(0-100点) ---
# score >= HIGH_SCORE_THRESHOLD: 🚨 HIGH PRIORITY(Discord通知)
HIGH_SCORE_THRESHOLD=90
# score >= WATCH_SCORE_THRESHOLD: ⚠ WATCH(Discord通知)
WATCH_SCORE_THRESHOLD=80
# score >= LOW_SCORE_THRESHOLD: ログ保存のみ(Discordへは送らない)
LOW_SCORE_THRESHOLD=70

# --- 通知後の結果トラッキング ---
# JSONLの出力先(未設定なら logs/outcomes.jsonl)。
OUTCOMES_FILE_PATH=

# --- ログ ---
LOG_LEVEL=INFO
