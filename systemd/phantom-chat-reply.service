[Unit]
Description=ARTEMIS Phantom Sniper Chat Reply Bot (chat_reply_bot.py, optional fun feature)
After=network.target

[Service]
Type=simple
User=__PHANTOM_USER__
WorkingDirectory=__PHANTOM_HOME__/artemis-ai-phantom
ExecStart=__PHANTOM_HOME__/artemis-ai-phantom/.venv/bin/python __PHANTOM_HOME__/artemis-ai-phantom/chat_reply_bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
