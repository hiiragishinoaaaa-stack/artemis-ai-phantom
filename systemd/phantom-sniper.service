[Unit]
Description=ARTEMIS Phantom Sniper (pump.fun new token watcher -> Discord)
After=network.target

[Service]
Type=simple
User=__PHANTOM_USER__
WorkingDirectory=__PHANTOM_HOME__/artemis-ai-phantom
ExecStart=__PHANTOM_HOME__/artemis-ai-phantom/.venv/bin/python __PHANTOM_HOME__/artemis-ai-phantom/main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
